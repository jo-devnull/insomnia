import "tags.pkl"
import "recipes/misc.pkl"
import "recipes/smelting.pkl"

function res(path) = "toolworking:\(path)"

function buildRecipes(object) = new Mapping<String, FileOutput> {
  for (group, list in object.toMap()) {
    for (recipe in list) {
      [recipe.getPath()] {
        value = recipe
        renderer = new JsonRenderer {}
      }
    }
  }
}

function buildTags(tags) = new Mapping<String, FileOutput> {
  for (name, items in tags.toMap()) {
    ["toolworking:tags/items/\(name)"] {
      value { values = items }
      renderer = new JsonRenderer {}
    }
  }
}

function build() = new Mapping<String, FileOutput> {
  ...buildTags(tags)
  ...buildRecipes(misc)
  ...buildRecipes(smelting)
}
