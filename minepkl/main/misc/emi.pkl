      "#forge:plates"
    }
    exclusions = new Listing {}
  }

  ["nuggets"] {
    id = "toolworking:pepita"
    type = "emixx:group"
    contents {
      "#forge:nuggets"
    }
    exclusions = new Listing {}
  }

  ["crushed_raw_materials"] {
    id = "toolworking:material_bruto_esmagado"
    type = "emixx:group"
    contents {
      "#create:crushed_raw_materials"
    }
    exclusions = new Listing {}
  }
}

